# ─────────────────────────────────────────────
#  SAPAN PORTFOLIO — BACKEND ENV VARIABLES
#  Copy this file to .env and fill in values
#  NEVER commit .env to git
# ─────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# CORS — set this to your frontend URL in production
# e.g. https://sapan-gandhi.vercel.app
FRONTEND_URL=http://localhost:5173

# ── EMAIL PROVIDER: Choose ONE of the options below ──

# ── OPTION A: Gmail (easiest for personal use) ──────
# 1. Go to Google Account > Security > 2-Step Verification > App Passwords
# 2. Generate an App Password for "Mail"
# 3. Paste it below (NOT your real Gmail password)
EMAIL_PROVIDER=gmail
GMAIL_USER=sapgandhi811@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password_here

# ── OPTION B: Resend (recommended for production) ───
# 1. Sign up at https://resend.com
# 2. Create an API key
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=re_your_resend_api_key_here
# RESEND_FROM=onboarding@resend.dev

# ── OPTION C: SMTP (any provider) ───────────────────
# EMAIL_PROVIDER=smtp
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=your_smtp_password

# Recipient (where contact form emails go)
CONTACT_RECEIVER=sapgandhi811@gmail.com

# ── AI CHATBOT (Claude API) ──────────────────────────────────────────────────
# Get your API key from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# ── CHATBOT (Optional but recommended) ──────────────────────────────────────
# Get your API key from https://console.anthropic.com
# If left empty, chatbot uses smart fallback responses (no AI)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
